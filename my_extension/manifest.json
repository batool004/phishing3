{
  "manifest_version": 3,
  "name": "Phishing URL Detector",
  "description": "Detect phishing websites directly from your browser",
  "version": "1.0",
  "permissions": ["tabs", "storage", "activeTab", "scripting", "notifications"],
  "host_permissions": ["http://localhost:5000/*", "https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "فحص الرابط - Phishing Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}